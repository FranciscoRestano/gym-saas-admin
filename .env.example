# Supabase - Variables de entorno requeridas
# Copiá este archivo como .env y completá con tus datos de Supabase

# URL del proyecto Supabase (Settings > API > Project URL)
PUBLIC_SUPABASE_URL=tu_url_de_supabase.aqui

# Anon Key de Supabase (Settings > API > anon public)
PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
