---
import '../styles/global.css';

const GIMNASIO_ID = '00000000-0000-0000-0000-000000000000';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-zinc-100 flex items-center justify-center p-4">
    <div class="w-full max-w-md space-y-8">
      <div class="text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-600 shadow-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7 text-white">
            <path d="M4 8h16a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1Z" />
            <path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            <path d="M3 13h18" />
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-bold tracking-tight text-zinc-900">Gym SaaS</h1>
        <p class="mt-1 text-sm text-zinc-500">Ingresá con tu rol</p>
      </div>

      <!-- Selector de Rol -->
      <div class="grid grid-cols-2 gap-2 rounded-xl bg-zinc-200/60 p-1">
        <button type="button" data-rol="alumno" class="rol-btn rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors bg-white text-zinc-900 shadow-sm">
          Soy Alumno
        </button>
        <button type="button" data-rol="profesor" class="rol-btn rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors text-zinc-500 hover:text-zinc-700">
          Soy Profesor
        </button>
      </div>

      <!-- Formulario Alumno -->
      <div id="form-alumno" class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-zinc-200 space-y-4">
        <div>
          <label for="alumno-dni" class="block text-sm font-medium text-zinc-700">Ingresá tu DNI</label>
          <input
            id="alumno-dni"
            type="text"
            required
            inputmode="numeric"
            autocomplete="off"
            placeholder="Ej: 40998221"
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <p id="error-alumno" class="hidden text-sm text-red-600"></p>
        <button
          id="btn-alumno"
          type="button"
          class="w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700 disabled:opacity-60"
        >
          Ingresar
        </button>
      </div>

      <!-- Formulario Profesor -->
      <div id="form-profesor" class="hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-zinc-200 space-y-4">
        <div>
          <label for="profesor-dni" class="block text-sm font-medium text-zinc-700">DNI</label>
          <input
            id="profesor-dni"
            type="text"
            required
            inputmode="numeric"
            autocomplete="off"
            placeholder="Ej: 40998221"
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <div>
          <label for="profesor-password" class="block text-sm font-medium text-zinc-700">Contraseña</label>
          <input
            id="profesor-password"
            type="password"
            required
            placeholder="••••••••"
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <p id="error-profesor" class="hidden text-sm text-red-600"></p>
        <button
          id="btn-profesor"
          type="button"
          class="w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700 disabled:opacity-60"
        >
          Ingresar
        </button>
      </div>

      <p class="text-center text-xs text-zinc-400">
        ¿Sos administrador? <a href="/admin" class="font-medium text-emerald-600 hover:text-emerald-700 hover:underline">Ingresá acá</a>
      </p>
    </div>

    <script>
      const GIMNASIO_ID = '00000000-0000-0000-0000-000000000000';

      let rolActivo: 'profesor' | 'alumno' = 'alumno';

      const formProfesor = document.getElementById('form-profesor');
      const formAlumno = document.getElementById('form-alumno');
      const btnProfesor = document.getElementById('btn-profesor') as HTMLButtonElement | null;
      const btnAlumno = document.getElementById('btn-alumno') as HTMLButtonElement | null;
      const errorProfesor = document.getElementById('error-profesor');
      const errorAlumno = document.getElementById('error-alumno');

      function mostrarError(el: HTMLElement | null, msg: string): void {
        if (!el) return;
        el.textContent = msg;
        el.classList.remove('hidden');
      }

      function ocultarError(el: HTMLElement | null): void {
        el?.classList.add('hidden');
      }

      function setLoading(btn: HTMLButtonElement | null, loading: boolean): void {
        if (!btn) return;
        btn.disabled = loading;
        btn.textContent = loading ? 'Ingresando…' : 'Ingresar';
      }

      // ── Selector de Rol ───────────────────────────────────────────
      document.querySelectorAll('[data-rol]').forEach((btn) => {
        btn.addEventListener('click', () => {
          rolActivo = (btn as HTMLElement).dataset.rol as 'profesor' | 'alumno';

          document.querySelectorAll('[data-rol]').forEach((b) => {
            const activo = (b as HTMLElement).dataset.rol === rolActivo;
            b.classList.toggle('bg-white', activo);
            b.classList.toggle('text-zinc-900', activo);
            b.classList.toggle('shadow-sm', activo);
            b.classList.toggle('text-zinc-500', !activo);
          });

          formProfesor?.classList.toggle('hidden', rolActivo !== 'profesor');
          formAlumno?.classList.toggle('hidden', rolActivo !== 'alumno');

          ocultarError(errorProfesor);
          ocultarError(errorAlumno);
        });
      });

      // ── Profesor: DNI + contraseña ────────────────────────────────
      btnProfesor?.addEventListener('click', async () => {
        ocultarError(errorProfesor);
        const dni = (document.getElementById('profesor-dni') as HTMLInputElement)?.value.trim();
        const password = (document.getElementById('profesor-password') as HTMLInputElement)?.value;

        if (!dni) {
          mostrarError(errorProfesor, 'Ingresá tu DNI.');
          return;
        }

        if (!password) {
          mostrarError(errorProfesor, 'Ingresá la contraseña.');
          return;
        }

        setLoading(btnProfesor, true);

        const res = await fetch('/api/login-profesor', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dni, password }),
        });

        setLoading(btnProfesor, false);

        if (!res.ok) {
          const data = await res.json();
          console.error('[login] Error:', data);
          mostrarError(errorProfesor, data.detail || data.error || 'Error al validar. Intentá de nuevo.');
          return;
        }

        const { id } = await res.json();
        localStorage.setItem('profesor_id', id);
        window.location.href = '/profesor/clientes';
      });

      // ── Enter para enviar ──────────────────────────────────────────
      document.getElementById('alumno-dni')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') btnAlumno?.click();
      });

      document.getElementById('profesor-dni')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') btnProfesor?.click();
      });

      document.getElementById('profesor-password')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') btnProfesor?.click();
      });

      // ── Alumno: solo DNI ──────────────────────────────────────────
      btnAlumno?.addEventListener('click', async () => {
        ocultarError(errorAlumno);
        const dni = (document.getElementById('alumno-dni') as HTMLInputElement)?.value.trim();

        if (!dni) {
          mostrarError(errorAlumno, 'Ingresá tu DNI.');
          return;
        }

        setLoading(btnAlumno, true);

        const res = await fetch('/api/login-alumno', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dni }),
        });

        setLoading(btnAlumno, false);

        if (!res.ok) {
          const data = await res.json();
          console.error('[login] Error:', data);
          mostrarError(errorAlumno, data.detail || data.error || 'Error al buscar. Intentá de nuevo.');
          return;
        }

        const { id } = await res.json();
        localStorage.setItem('alumno_id', id);
        window.location.href = '/alumno/mi-rutina';
      });
    </script>
  </body>
</html>
