---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Paginacion from '../../components/Paginacion.astro';

const iconDumbbell = `<path d="M14.4 14.4 9.6 9.6" /><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767-1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l1.767 1.767a2 2 0 1 1 2.828 2.829z" /><path d="m21.5 21.5-1.4-1.4" /><path d="M3.9 3.9 2.5 2.5" /><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767 1.768a2 2 0 1 1 2.829 2.828z" />`;
const iconPlus = `<path d="M12 5v14M5 12h14" />`;
const iconSearch = `<circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />`;
---

<DashboardLayout title="Ejercicios">
  <div class="space-y-6">
    <div class="flex items-center justify-between gap-3 w-full">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">Ejercicios</h1>
        <p class="mt-1 text-sm text-zinc-500">Catálogo global de ejercicios disponibles para armar rutinas.</p>
      </div>
      <button
        id="btn-nuevo-ejercicio"
        type="button"
        aria-haspopup="dialog"
        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4" set:html={iconPlus} />
        Nuevo Ejercicio
      </button>
    </div>

    <!-- Error -->
    <div id="ejercicios-error" class="hidden items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-5 w-5 shrink-0">
        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
        <path d="M12 9v4M12 17h.01" />
      </svg>
      <div class="flex-1">
        <span id="ejercicios-error-mensaje"></span>
        <button id="btn-reintentar" type="button" class="ml-2 font-semibold underline hover:no-underline">Reintentar</button>
      </div>
    </div>

    <!-- Cargando -->
    <p id="ejercicios-cargando" class="px-1 py-10 text-center text-sm text-zinc-500">Cargando ejercicios…</p>

    <!-- Vacío -->
    <div id="ejercicios-vacio" class="hidden flex-col items-center justify-center gap-5 rounded-2xl border border-dashed border-zinc-200 bg-zinc-50/80 px-8 py-16 text-center">
      <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-zinc-400 shadow-sm ring-1 ring-zinc-200">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7" set:html={iconDumbbell} />
      </span>
      <div class="space-y-1.5">
        <p class="text-base font-semibold text-zinc-800">No hay ejercicios en el catálogo</p>
        <p class="max-w-xs text-sm leading-relaxed text-zinc-500">
          Creá el primer ejercicio para empezar a armar rutinas personalizadas.
        </p>
      </div>
      <button
        id="btn-nuevo-ejercicio-vacio"
        type="button"
        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4" set:html={iconPlus} />
        Nuevo Ejercicio
      </button>
    </div>

    <!-- Contenido principal -->
    <div id="ejercicios-contenido" class="hidden space-y-4">
      <!-- Barra de filtros -->
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="relative flex-1 max-w-xs">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400" set:html={iconSearch} />
          <input
            id="input-buscar"
            type="text"
            placeholder="Buscar ejercicio…"
            autocomplete="off"
            class="w-full rounded-lg border border-zinc-300 bg-white py-2 pl-9 pr-3 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <div id="filtro-grupos" class="flex flex-wrap gap-1.5">
          <button type="button" data-grupo="Todos" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-emerald-600 text-white">Todos</button>
          <button type="button" data-grupo="Pecho" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Pecho</button>
          <button type="button" data-grupo="Espalda" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Espalda</button>
          <button type="button" data-grupo="Hombros" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Hombros</button>
          <button type="button" data-grupo="Bíceps" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Bíceps</button>
          <button type="button" data-grupo="Tríceps" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Tríceps</button>
          <button type="button" data-grupo="Cuádriceps" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Cuádriceps</button>
          <button type="button" data-grupo="Isquiotibiales" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Isquiotibiales</button>
          <button type="button" data-grupo="Gemelos" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Gemelos</button>
          <button type="button" data-grupo="Aductores" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Aductores</button>
          <button type="button" data-grupo="Core" class="btn-grupo rounded-lg px-3 py-1.5 text-xs font-semibold transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200">Core</button>
        </div>
      </div>

      <!-- Tabla -->
      <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-zinc-200">
            <thead class="bg-zinc-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Ejercicio</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Grupo Muscular</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-zinc-500">Acciones</th>
              </tr>
            </thead>
            <tbody id="tabla-ejercicios" class="divide-y divide-zinc-100"></tbody>
          </table>
        </div>
        <p id="sin-resultados" class="hidden px-6 py-10 text-center text-sm text-zinc-500">No se encontraron ejercicios con esos filtros.</p>
      </div>
      <Paginacion id="pag-ejercicios" />
    </div>
  </div>

  <!-- Modal Nuevo Ejercicio -->
  <div id="modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-900/50 p-4">
    <div role="dialog" aria-modal="true" aria-labelledby="modal-titulo" class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
      <div class="flex items-center justify-between">
        <h2 id="modal-titulo" class="text-lg font-semibold text-zinc-900">Nuevo Ejercicio</h2>
        <button id="btn-cerrar-modal" type="button" aria-label="Cerrar" class="rounded-md p-1 text-zinc-400 hover:bg-zinc-100 hover:text-zinc-600">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5">
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="form-nuevo-ejercicio" class="mt-5 space-y-4">
        <div>
          <label for="input-nombre" class="block text-sm font-medium text-zinc-700">Nombre</label>
          <input
            id="input-nombre"
            name="nombre"
            type="text"
            required
            autocomplete="off"
            placeholder="Ej: Sentadilla con barra"
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <div>
          <label for="select-grupo" class="block text-sm font-medium text-zinc-700">Grupo Muscular</label>
          <select
            id="select-grupo"
            name="grupo_muscular"
            required
            class="mt-1 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          >
            <option value="" disabled selected>Seleccioná un grupo</option>
            <option value="Pecho">Pecho</option>
            <option value="Espalda">Espalda</option>
            <option value="Hombros">Hombros</option>
            <option value="Bíceps">Bíceps</option>
            <option value="Tríceps">Tríceps</option>
            <option value="Cuádriceps">Cuádriceps</option>
            <option value="Isquiotibiales">Isquiotibiales</option>
            <option value="Gemelos">Gemelos</option>
            <option value="Aductores">Aductores</option>
            <option value="Core">Core</option>
          </select>
        </div>

        <p id="form-error" class="hidden text-sm text-red-600"></p>

        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="btn-cancelar-modal" class="rounded-lg px-4 py-2 text-sm font-medium text-zinc-600 hover:bg-zinc-100">Cancelar</button>
          <button
            type="submit"
            id="btn-guardar"
            class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700 disabled:opacity-60"
          >
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { itemsPagina, renderizarPaginacion, type EstadoPagina } from '../../lib/paginacion';

  interface EjercicioRow {
    id: string;
    nombre: string;
    grupo_muscular: string;
  }

  let todosLosEjercicios: EjercicioRow[] = [];
  let grupoActivo = 'Todos';
  let textoBusqueda = '';
  let estadoPagina: EstadoPagina = { items: [], paginaActual: 1 };

  const cargandoEl = document.getElementById('ejercicios-cargando');
  const vacioEl = document.getElementById('ejercicios-vacio');
  const contenidoEl = document.getElementById('ejercicios-contenido');
  const tablaEl = document.getElementById('tabla-ejercicios');
  const sinResultados = document.getElementById('sin-resultados');
  const errorEl = document.getElementById('ejercicios-error');
  const errorMensajeEl = document.getElementById('ejercicios-error-mensaje');
  const btnReintentar = document.getElementById('btn-reintentar');
  const inputBuscar = document.getElementById('input-buscar') as HTMLInputElement | null;

  const modalOverlay = document.getElementById('modal-overlay');
  const formNuevo = document.getElementById('form-nuevo-ejercicio') as HTMLFormElement | null;
  const formError = document.getElementById('form-error');
  const btnGuardar = document.getElementById('btn-guardar') as HTMLButtonElement | null;

  function mostrarError(mensaje: string | null): void {
    const hayError = mensaje !== null;
    if (errorMensajeEl && mensaje) errorMensajeEl.textContent = mensaje;
    errorEl?.classList.toggle('hidden', !hayError);
    errorEl?.classList.toggle('flex', hayError);
  }

  function mostrarVacio(visible: boolean): void {
    vacioEl?.classList.toggle('hidden', !visible);
    vacioEl?.classList.toggle('flex', visible);
  }

  function abrirModal(): void {
    modalOverlay?.classList.remove('hidden');
    modalOverlay?.classList.add('flex');
    document.getElementById('input-nombre')?.focus();
  }

  function cerrarModal(): void {
    modalOverlay?.classList.add('hidden');
    modalOverlay?.classList.remove('flex');
    formNuevo?.reset();
    formError?.classList.add('hidden');
  }

  function crearFila(ejercicio: EjercicioRow): HTMLTableRowElement {
    const fila = document.createElement('tr');
    fila.className = 'hover:bg-zinc-50 transition-colors';
    fila.dataset.id = ejercicio.id;

    fila.innerHTML = `
      <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-zinc-900">${ejercicio.nombre}</td>
      <td class="whitespace-nowrap px-6 py-4 text-sm text-zinc-600">
        <span class="inline-flex items-center rounded-full bg-zinc-100 px-2.5 py-1 text-xs font-medium text-zinc-700 ring-1 ring-inset ring-zinc-200">${ejercicio.grupo_muscular}</span>
      </td>
      <td class="whitespace-nowrap px-6 py-4 text-right">
        <button
          type="button"
          data-eliminar
          data-id="${ejercicio.id}"
          data-nombre="${ejercicio.nombre}"
          class="inline-flex items-center justify-center rounded-md p-1.5 text-zinc-400 transition-colors hover:bg-red-50 hover:text-red-600"
          aria-label="Eliminar ejercicio"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <path d="M3 6h18" />
            <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" />
            <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
          </svg>
        </button>
      </td>
    `;

    return fila;
  }

  function aplicarFiltros(): void {
    const busqueda = textoBusqueda.toLowerCase();

    const filtrados = todosLosEjercicios.filter((ej) => {
      const coincideGrupo = grupoActivo === 'Todos' || ej.grupo_muscular === grupoActivo;
      const coincideNombre = !busqueda || ej.nombre.toLowerCase().includes(busqueda);
      return coincideGrupo && coincideNombre;
    });

    estadoPagina.items = filtrados;
    if (estadoPagina.paginaActual > 1 && (estadoPagina.paginaActual - 1) * 10 >= filtrados.length) {
      estadoPagina.paginaActual = 1;
    }

    const paginaItems = itemsPagina(filtrados, estadoPagina.paginaActual);

    if (tablaEl) {
      tablaEl.replaceChildren(...paginaItems.map((ej) => crearFila(ej)));
    }

    if (sinResultados) {
      sinResultados.classList.toggle('hidden', filtrados.length > 0);
    }

    renderizarPaginacion('pag-ejercicios', estadoPagina, (pagina) => {
      estadoPagina.paginaActual = pagina;
      aplicarFiltros();
    });
  }

  async function cargarDatos(): Promise<void> {
    mostrarError(null);
    if (cargandoEl) cargandoEl.hidden = false;
    contenidoEl?.classList.add('hidden');
    mostrarVacio(false);

    const res = await fetch('/api/admin/ejercicios');
    const json = await res.json();

    if (cargandoEl) cargandoEl.hidden = true;

    if (!res.ok || json.error) {
      mostrarError(`No se pudieron cargar los ejercicios: ${json.error ?? 'Error desconocido'}`);
      return;
    }

    todosLosEjercicios = (json.ejercicios ?? []) as EjercicioRow[];

    if (todosLosEjercicios.length === 0) {
      mostrarVacio(true);
      return;
    }

    aplicarFiltros();
    contenidoEl?.classList.remove('hidden');
  }

  btnReintentar?.addEventListener('click', () => void cargarDatos());
  document.getElementById('btn-nuevo-ejercicio')?.addEventListener('click', abrirModal);
  document.getElementById('btn-nuevo-ejercicio-vacio')?.addEventListener('click', abrirModal);
  document.getElementById('btn-cerrar-modal')?.addEventListener('click', cerrarModal);
  document.getElementById('btn-cancelar-modal')?.addEventListener('click', cerrarModal);

  modalOverlay?.addEventListener('click', (evento) => {
    if (evento.target === modalOverlay) cerrarModal();
  });

  inputBuscar?.addEventListener('input', () => {
    textoBusqueda = inputBuscar.value;
    aplicarFiltros();
  });

  document.getElementById('filtro-grupos')?.addEventListener('click', (evento) => {
    const btn = (evento.target as HTMLElement).closest('[data-grupo]') as HTMLButtonElement | null;
    if (!btn) return;

    grupoActivo = btn.dataset.grupo ?? 'Todos';

    document.querySelectorAll('.btn-grupo').forEach((b) => {
      const activo = b.getAttribute('data-grupo') === grupoActivo;
      b.classList.toggle('bg-emerald-600', activo);
      b.classList.toggle('text-white', activo);
      b.classList.toggle('bg-zinc-100', !activo);
      b.classList.toggle('text-zinc-600', !activo);
    });

    aplicarFiltros();
  });

  formNuevo?.addEventListener('submit', async (evento) => {
    evento.preventDefault();
    if (!formNuevo || !btnGuardar) return;

    const datos = new FormData(formNuevo);
    const nombre = String(datos.get('nombre') ?? '').trim();
    const grupoMuscular = String(datos.get('grupo_muscular') ?? '').trim();

    if (!nombre || !grupoMuscular) {
      if (formError) {
        formError.textContent = 'Completá nombre y grupo muscular.';
        formError.classList.remove('hidden');
      }
      return;
    }

    btnGuardar.disabled = true;
    btnGuardar.textContent = 'Guardando…';

    const res = await fetch('/api/admin/ejercicios', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nombre, grupo_muscular: grupoMuscular }),
    });
    const json = await res.json();

    btnGuardar.disabled = false;
    btnGuardar.textContent = 'Guardar';

    if (!res.ok || json.error) {
      if (formError) {
        formError.textContent = `Error: ${json.error ?? 'Error desconocido'}`;
        formError.classList.remove('hidden');
      }
      return;
    }

    if (json.ejercicio) {
      todosLosEjercicios.push(json.ejercicio as EjercicioRow);
    }

    cerrarModal();
    aplicarFiltros();

    if (todosLosEjercicios.length > 0 && contenidoEl?.classList.contains('hidden')) {
      contenidoEl.classList.remove('hidden');
      mostrarVacio(false);
    }
  });

  document.addEventListener('click', async (evento) => {
    const objetivo = evento.target as HTMLElement;
    const btn = objetivo.closest('[data-eliminar]') as HTMLButtonElement | null;
    if (!btn) return;

    evento.preventDefault();
    const id = btn.dataset.id;
    const nombre = btn.dataset.nombre;
    if (!id) return;

    const confirmado = window.confirm(`¿Eliminar el ejercicio "${nombre}"? Esta acción no se puede deshacer.`);
    if (!confirmado) return;

    btn.disabled = true;

    const res = await fetch('/api/admin/ejercicios', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    const json = await res.json();

    btn.disabled = false;

    if (!res.ok || json.error) {
      window.alert(`Error al eliminar: ${json.error ?? 'Error desconocido'}`);
      return;
    }

    todosLosEjercicios = todosLosEjercicios.filter((ej) => ej.id !== id);
    aplicarFiltros();

    if (todosLosEjercicios.length === 0) {
      contenidoEl?.classList.add('hidden');
      mostrarVacio(true);
    }
  });

  void cargarDatos();
</script>
