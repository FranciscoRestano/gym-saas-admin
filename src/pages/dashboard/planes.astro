---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const iconPlus = `<path d="M12 5v14M5 12h14" />`;
const iconGrid = `<path d="M3 3h7v7H3zm11 0h7v7h-7zM3 14h7v7H3zm11 0h7v7h-7z" />`;
---

<DashboardLayout title="Planes">
  <div class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">Planes</h1>
        <p class="mt-1 text-sm text-zinc-500">Catálogo dinámico de modalidades y precios de tu gimnasio.</p>
      </div>
      <button
        id="btn-nuevo-plan"
        type="button"
        aria-haspopup="dialog"
        aria-controls="modal-overlay"
        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4" set:html={iconPlus} />
        Nuevo Plan
      </button>
    </div>

    <div id="planes-error" class="hidden items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-5 w-5 shrink-0">
        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
        <path d="M12 9v4M12 17h.01" />
      </svg>
      <div class="flex-1">
        <span id="planes-error-mensaje"></span>
        <button id="btn-reintentar" type="button" class="ml-2 font-semibold underline hover:no-underline">Reintentar</button>
      </div>
    </div>

    <p id="planes-cargando" class="px-1 py-10 text-center text-sm text-zinc-500">Cargando catálogo de planes…</p>

    <div id="planes-vacio" class="hidden flex-col items-center justify-center gap-5 rounded-2xl border border-dashed border-zinc-200 bg-zinc-50/80 px-8 py-16 text-center">
      <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-zinc-400 shadow-sm ring-1 ring-zinc-200">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7" set:html={iconGrid} />
      </span>
      <div class="space-y-1.5">
        <p class="text-base font-semibold text-zinc-800">Todavía no tenés planes</p>
        <p class="max-w-xs text-sm leading-relaxed text-zinc-500">
          Creá tu primer plan para definir modalidades y precios del gimnasio.
        </p>
      </div>
      <button
        id="btn-nuevo-plan-vacio"
        type="button"
        aria-haspopup="dialog"
        aria-controls="modal-overlay"
        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4" set:html={iconPlus} />
        Nuevo Plan
      </button>
    </div>

    <div id="planes-contenido" class="hidden">
      <div id="grilla-planes" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
    </div>
  </div>

  <div id="modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-900/50 p-4">
    <div role="dialog" aria-modal="true" aria-labelledby="modal-titulo" class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
      <div class="flex items-center justify-between">
        <h2 id="modal-titulo" class="text-lg font-semibold text-zinc-900">Nuevo Plan</h2>
        <button id="btn-cerrar-modal" type="button" aria-label="Cerrar" class="rounded-md p-1 text-zinc-400 hover:bg-zinc-100 hover:text-zinc-600">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5">
            <path d="M6 6l12 12M18 6 6 18" />
          </svg>
        </button>
      </div>

      <form id="form-nuevo-plan" class="mt-5 space-y-4">
        <div>
          <label for="input-nombre-plan" class="block text-sm font-medium text-zinc-700">Nombre del Plan</label>
          <input
            id="input-nombre-plan"
            name="nombre"
            type="text"
            required
            autocomplete="off"
            placeholder="Ej: Semipersonalizada · 3 días/semana"
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
          />
        </div>
        <div>
          <label for="input-precio" class="block text-sm font-medium text-zinc-700">Precio</label>
          <div class="relative mt-1">
            <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-sm text-zinc-400">$</span>
            <input
              id="input-precio"
              name="precio"
              type="number"
              min="0"
              step="100"
              required
              placeholder="0"
              class="w-full rounded-lg border border-zinc-300 py-2 pl-7 pr-3 text-sm text-zinc-900 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
            />
          </div>
        </div>

        <p id="form-error" class="hidden text-sm text-red-600"></p>

        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="btn-cancelar-modal" class="rounded-lg px-4 py-2 text-sm font-medium text-zinc-600 hover:bg-zinc-100">Cancelar</button>
          <button
            type="submit"
            id="btn-guardar-plan"
            class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700 disabled:opacity-60"
          >
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  const GIMNASIO_ID = '00000000-0000-0000-0000-000000000000';

  function resolverGimnasioId(): string {
    return GIMNASIO_ID;
  }

  interface PlanRow {
    id: string;
    nombre: string;
    precio: number;
  }

  const cargandoEl = document.getElementById('planes-cargando');
  const vacioEl = document.getElementById('planes-vacio');
  const contenidoEl = document.getElementById('planes-contenido');
  const grillaPlanes = document.getElementById('grilla-planes');
  const errorEl = document.getElementById('planes-error');
  const errorMensajeEl = document.getElementById('planes-error-mensaje');
  const btnReintentar = document.getElementById('btn-reintentar');

  const modalOverlay = document.getElementById('modal-overlay');
  const modalTitulo = document.getElementById('modal-titulo');
  const formNuevoPlan = document.getElementById('form-nuevo-plan') as HTMLFormElement | null;
  const inputNombrePlan = document.getElementById('input-nombre-plan') as HTMLInputElement | null;
  const inputPrecioPlan = document.getElementById('input-precio') as HTMLInputElement | null;
  const formError = document.getElementById('form-error');
  const btnGuardarPlan = document.getElementById('btn-guardar-plan') as HTMLButtonElement | null;

  let planEditandoId: string | null = null;

  function formatARS(monto: number): string {
    return monto.toLocaleString('es-AR');
  }

  function mostrarError(mensaje: string | null): void {
    const hayError = mensaje !== null;
    if (errorMensajeEl && mensaje) errorMensajeEl.textContent = mensaje;
    errorEl?.classList.toggle('hidden', !hayError);
    errorEl?.classList.toggle('flex', hayError);
  }

  function mostrarVacio(visible: boolean): void {
    vacioEl?.classList.toggle('hidden', !visible);
    vacioEl?.classList.toggle('flex', visible);
  }

  function crearBotonAccion(
    ariaLabel: string,
    className: string,
    paths: string,
    onClick: () => void,
  ): HTMLButtonElement {
    const boton = document.createElement('button');
    boton.type = 'button';
    boton.setAttribute('aria-label', ariaLabel);
    boton.className = className;
    boton.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">${paths}</svg>`;
    boton.addEventListener('click', onClick);
    return boton;
  }

  async function eliminarPlan(plan: PlanRow): Promise<void> {
    const confirmado = confirm(`¿Eliminar el plan "${plan.nombre}"? Esta acción no se puede deshacer.`);
    if (!confirmado) return;

    const res = await fetch('/api/admin/planes', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: plan.id }),
    });
    const json = await res.json();

    if (!res.ok || json.error) {
      mostrarError(`No se pudo eliminar el plan: ${json.error ?? 'Error desconocido'}`);
      return;
    }

    await cargarPlanes();
  }

  function crearCardPlan(plan: PlanRow): HTMLDivElement {
    const card = document.createElement('div');
    card.className = 'flex flex-col justify-between gap-4 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm';

    const cuerpo = document.createElement('div');

    const nombre = document.createElement('p');
    nombre.className = 'font-semibold text-zinc-900';
    nombre.textContent = plan.nombre;

    const precio = document.createElement('p');
    precio.className = 'mt-3 text-2xl font-bold tabular-nums tracking-tight text-zinc-900';
    precio.textContent = `$${formatARS(plan.precio)}`;

    cuerpo.append(nombre, precio);

    const acciones = document.createElement('div');
    acciones.className = 'flex items-center justify-end gap-1 border-t border-zinc-100 pt-3';

    const btnEditar = crearBotonAccion(
      'Editar plan',
      'rounded-lg p-2 text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-800',
      '<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/>',
      () => abrirModalEditar(plan),
    );

    const btnEliminar = crearBotonAccion(
      'Eliminar plan',
      'rounded-lg p-2 text-zinc-500 transition-colors hover:bg-red-50 hover:text-red-600',
      '<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>',
      () => void eliminarPlan(plan),
    );

    acciones.append(btnEditar, btnEliminar);
    card.append(cuerpo, acciones);
    return card;
  }

  async function cargarPlanes(): Promise<void> {
    mostrarError(null);
    if (cargandoEl) cargandoEl.hidden = false;
    contenidoEl?.classList.add('hidden');
    mostrarVacio(false);

    const res = await fetch('/api/admin/planes');
    const json = await res.json();

    if (cargandoEl) cargandoEl.hidden = true;

    if (!res.ok || json.error) {
      mostrarError(`No se pudo cargar el catálogo: ${json.error ?? 'Error desconocido'}`);
      return;
    }

    const planes = (json.planes ?? []) as PlanRow[];

    if (planes.length === 0) {
      mostrarVacio(true);
      return;
    }

    if (grillaPlanes) {
      grillaPlanes.replaceChildren(...planes.map(crearCardPlan));
    }
    contenidoEl?.classList.remove('hidden');
  }

  btnReintentar?.addEventListener('click', cargarPlanes);

  function abrirModalBase(): void {
    modalOverlay?.classList.remove('hidden');
    modalOverlay?.classList.add('flex');
    inputNombrePlan?.focus();
  }

  function abrirModalCrear(): void {
    planEditandoId = null;
    if (modalTitulo) modalTitulo.textContent = 'Nuevo Plan';
    formNuevoPlan?.reset();
    formError?.classList.add('hidden');
    abrirModalBase();
  }

  function abrirModalEditar(plan: PlanRow): void {
    planEditandoId = plan.id;
    if (modalTitulo) modalTitulo.textContent = 'Editar Plan';
    if (inputNombrePlan) inputNombrePlan.value = plan.nombre;
    if (inputPrecioPlan) inputPrecioPlan.value = String(plan.precio);
    formError?.classList.add('hidden');
    abrirModalBase();
  }

  function cerrarModal(): void {
    planEditandoId = null;
    modalOverlay?.classList.add('hidden');
    modalOverlay?.classList.remove('flex');
    if (modalTitulo) modalTitulo.textContent = 'Nuevo Plan';
    formNuevoPlan?.reset();
    formError?.classList.add('hidden');
  }

  document.getElementById('btn-nuevo-plan')?.addEventListener('click', abrirModalCrear);
  document.getElementById('btn-nuevo-plan-vacio')?.addEventListener('click', abrirModalCrear);
  document.getElementById('btn-cerrar-modal')?.addEventListener('click', cerrarModal);
  document.getElementById('btn-cancelar-modal')?.addEventListener('click', cerrarModal);

  formNuevoPlan?.addEventListener('submit', async (evento) => {
    evento.preventDefault();
    if (!formNuevoPlan || !btnGuardarPlan) return;

    const datos = new FormData(formNuevoPlan);
    const nombre = String(datos.get('nombre') ?? '').trim();
    const precio = Number(datos.get('precio') ?? 0);
    const gimnasioId = resolverGimnasioId();

    btnGuardarPlan.disabled = true;
    btnGuardarPlan.textContent = 'Guardando…';

    const res = await fetch('/api/admin/planes', {
      method: planEditandoId ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(planEditandoId
        ? { id: planEditandoId, nombre, precio }
        : { nombre, precio }),
    });
    const json = await res.json();

    btnGuardarPlan.disabled = false;
    btnGuardarPlan.textContent = 'Guardar';

    if (!res.ok || json.error) {
      if (formError) {
        formError.textContent = `Error: ${json.error ?? 'Error desconocido'}`;
        formError.classList.remove('hidden');
      }
      return;
    }

    cerrarModal();
    await cargarPlanes();
  });

  cargarPlanes();
</script>
