---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Paginacion from '../../components/Paginacion.astro';

const iconDollar = `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />`;
const iconCalendar = `<rect width="18" height="18" x="3" y="4" rx="2" ry="2" /><path d="M16 2v4M8 2v4M3 10h18" />`;
const iconReceipt = `<path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z" /><path d="M14 8H8M16 12H8M13 16H8" />`;
---

<DashboardLayout title="Caja">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">Caja</h1>
      <p class="mt-1 text-sm text-zinc-500">Historial de ingresos por pagos registrados.</p>
    </div>

    <!-- Métricas -->
    <div id="caja-metricas" class="hidden grid-cols-1 gap-4 sm:grid-cols-4">
      <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={iconDollar} />
          </span>
          <div>
            <p class="text-sm font-medium text-zinc-500">Ingresos Totales</p>
            <p id="metrica-total" class="text-2xl font-semibold text-zinc-900">—</p>
          </div>
        </div>
      </div>
      <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={iconCalendar} />
          </span>
          <div>
            <p class="text-sm font-medium text-zinc-500">Ingresos de Hoy</p>
            <p id="metrica-hoy" class="text-2xl font-semibold text-zinc-900">—</p>
          </div>
        </div>
      </div>
      <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={iconReceipt} />
          </span>
          <div>
            <p class="text-sm font-medium text-zinc-500">Total Transacciones</p>
            <p id="metrica-transacciones" class="text-2xl font-semibold text-zinc-900">—</p>
          </div>
        </div>
      </div>
      <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-violet-50 text-violet-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-zinc-500">Desglose por Método</p>
            <p id="metrica-desglose" class="text-sm font-medium text-zinc-700">—</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Error -->
    <div id="caja-error" class="hidden items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-5 w-5 shrink-0">
        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
        <path d="M12 9v4M12 17h.01" />
      </svg>
      <div class="flex-1">
        <span id="caja-error-mensaje"></span>
        <button id="btn-reintentar" type="button" class="ml-2 font-semibold underline hover:no-underline">Reintentar</button>
      </div>
    </div>

    <!-- Cargando -->
    <p id="caja-cargando" class="px-1 py-10 text-center text-sm text-zinc-500">Cargando movimientos…</p>

    <!-- Vacío -->
    <div id="caja-vacio" class="hidden flex-col items-center justify-center gap-5 rounded-2xl border border-dashed border-zinc-200 bg-zinc-50/80 px-8 py-16 text-center">
      <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-zinc-400 shadow-sm ring-1 ring-zinc-200">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7" set:html={iconDollar} />
      </span>
      <div class="space-y-1.5">
        <p class="text-base font-semibold text-zinc-800">No hay pagos registrados</p>
        <p class="max-w-xs text-sm leading-relaxed text-zinc-500">
          Los ingresos aparecerán acá cuando se registren pagos en la sección de Clientes.
        </p>
      </div>
    </div>

    <!-- Contenido principal -->
    <div id="caja-contenido" class="hidden">
      <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-zinc-200">
            <thead class="bg-zinc-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Fecha</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Alumno</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Plan</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Medio de Pago</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-zinc-500">Monto</th>
              </tr>
            </thead>
            <tbody id="tabla-caja" class="divide-y divide-zinc-100"></tbody>
          </table>
        </div>
      </div>
      <Paginacion id="pag-caja" />
    </div>
  </div>
</DashboardLayout>

<script>
  import { itemsPagina, renderizarPaginacion, type EstadoPagina } from '../../lib/paginacion';

  let estadoPagina: EstadoPagina = { items: [], paginaActual: 1 };

  interface PagoEnriquecido {
    cliente_nombre: string;
    plan_nombre: string;
    fecha_pago: string | null;
    monto_pagado: number | null;
    metodo_pago: string | null;
  }

  const cargandoEl = document.getElementById('caja-cargando');
  const vacioEl = document.getElementById('caja-vacio');
  const contenidoEl = document.getElementById('caja-contenido');
  const metricasEl = document.getElementById('caja-metricas');
  const tablaCaJa = document.getElementById('tabla-caja');
  const errorEl = document.getElementById('caja-error');
  const errorMensajeEl = document.getElementById('caja-error-mensaje');
  const btnReintentar = document.getElementById('btn-reintentar');
  const metricaTotal = document.getElementById('metrica-total');
  const metricaHoy = document.getElementById('metrica-hoy');
  const metricaTransacciones = document.getElementById('metrica-transacciones');

  function formatFecha(iso: string | null): string {
    if (!iso) return '—';
    const [year, month, day] = iso.split('-');
    if (!year || !month || !day) return iso;
    return `${day}/${month}/${year}`;
  }

  function formatMonto(valor: number | null): string {
    if (valor == null) return '—';
    return '$' + valor.toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
  }

  function hoyISO(): string {
    const ahora = new Date();
    return `${ahora.getFullYear()}-${String(ahora.getMonth() + 1).padStart(2, '0')}-${String(ahora.getDate()).padStart(2, '0')}`;
  }

  function mostrarError(mensaje: string | null): void {
    const hayError = mensaje !== null;
    if (errorMensajeEl && mensaje) errorMensajeEl.textContent = mensaje;
    errorEl?.classList.toggle('hidden', !hayError);
    errorEl?.classList.toggle('flex', hayError);
  }

  function mostrarVacio(visible: boolean): void {
    vacioEl?.classList.toggle('hidden', !visible);
    vacioEl?.classList.toggle('flex', visible);
  }

  function actualizarMetricas(pagos: PagoEnriquecido[]): void {
    const hoy = hoyISO();
    const totalIngresos = pagos.reduce((s, p) => s + (p.monto_pagado ?? 0), 0);
    const ingresosHoy = pagos.filter((p) => p.fecha_pago === hoy).reduce((s, p) => s + (p.monto_pagado ?? 0), 0);
    const efectivo = pagos.filter((p) => p.metodo_pago === 'Efectivo').reduce((s, p) => s + (p.monto_pagado ?? 0), 0);
    const transferencia = pagos.filter((p) => p.metodo_pago === 'Transferencia').reduce((s, p) => s + (p.monto_pagado ?? 0), 0);

    if (metricaTotal) metricaTotal.textContent = formatMonto(totalIngresos);
    if (metricaHoy) metricaHoy.textContent = formatMonto(ingresosHoy);
    if (metricaTransacciones) metricaTransacciones.textContent = String(pagos.length);

    const metricaDesglose = document.getElementById('metrica-desglose');
    if (metricaDesglose) {
      metricaDesglose.innerHTML = `
        <span class="text-emerald-600">Efectivo: ${formatMonto(efectivo)}</span>
        <span class="mx-2 text-zinc-300">|</span>
        <span class="text-blue-600">Transferencia: ${formatMonto(transferencia)}</span>
      `;
    }
  }

  function crearFila(pago: PagoEnriquecido): HTMLTableRowElement {
    const fila = document.createElement('tr');
    fila.className = 'hover:bg-zinc-50 transition-colors';
    const metodoPago = pago.metodo_pago ?? 'Efectivo';
    fila.innerHTML = `
      <td class="whitespace-nowrap px-6 py-4 text-sm text-zinc-600 tabular-nums">${formatFecha(pago.fecha_pago)}</td>
      <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-zinc-900">${pago.cliente_nombre}</td>
      <td class="whitespace-nowrap px-6 py-4 text-sm text-zinc-600">${pago.plan_nombre}</td>
      <td class="whitespace-nowrap px-6 py-4 text-sm text-zinc-600">
        <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium ${metodoPago === 'Efectivo' ? 'bg-emerald-50 text-emerald-700' : 'bg-blue-50 text-blue-700'}">${metodoPago}</span>
      </td>
      <td class="whitespace-nowrap px-6 py-4 text-sm text-right font-medium text-zinc-900 tabular-nums">${formatMonto(pago.monto_pagado)}</td>
    `;
    return fila;
  }

  async function cargarDatos(): Promise<void> {
    mostrarError(null);
    if (cargandoEl) cargandoEl.hidden = false;
    contenidoEl?.classList.add('hidden');
    metricasEl?.classList.add('hidden');
    mostrarVacio(false);

    const res = await fetch('/api/admin/caja');

    if (cargandoEl) cargandoEl.hidden = true;

    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: 'Error desconocido' }));
      mostrarError(`No se pudieron cargar los pagos: ${err.error}`);
      return;
    }

    const { pagos, clientes, planes } = await res.json();

    if (pagos.length === 0) {
      mostrarVacio(true);
      return;
    }

    const pagosEnriquecidos: PagoEnriquecido[] = pagos.map((p) => ({
      ...p,
      cliente_nombre: clientes[p.cliente_id] ?? '—',
      plan_nombre: p.plan_id ? (planes[p.plan_id] ?? '—') : '—',
    }));

    actualizarMetricas(pagosEnriquecidos);

    estadoPagina.items = pagosEnriquecidos;
    estadoPagina.paginaActual = 1;
    renderizarTabla();
    renderizarPaginacion('pag-caja', estadoPagina, (pagina) => { estadoPagina.paginaActual = pagina; renderizarTabla(); });

    contenidoEl?.classList.remove('hidden');
    metricasEl?.classList.remove('hidden');
  }

  function renderizarTabla(): void {
    if (!tablaCaJa) return;
    const pagina = itemsPagina(estadoPagina.items, estadoPagina.paginaActual);
    tablaCaJa.replaceChildren(...pagina.map((pago) => crearFila(pago as PagoEnriquecido)));
  }

  btnReintentar?.addEventListener('click', () => void cargarDatos());
  void cargarDatos();
</script>
